MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/heights-connect
PORT=3000

# JWT secret — use any long random string in production
JWT_SECRET=change-this-to-a-long-random-secret

# Admin credentials
ADMIN_USERNAME=admin
# Generate the hash by running: node scripts/generate-hash.js yourpassword
ADMIN_PASSWORD_HASH=$2b$10$...paste-hash-here...
